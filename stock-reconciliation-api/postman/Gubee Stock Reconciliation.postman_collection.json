      "name": "Cenário 1 - STOCK_ADJUSTED",
      "item": [
        {
          "name": "1.1 - Ajuste de estoque (available=10)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status HTTP deve ser 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status do evento deve ser PROCESSED', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('PROCESSED');",
                  "});",
                  "pm.test('EventId deve ser retornado', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.eventId).to.eql('e2e-s1-adj');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt-BR"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"e2e-s1-adj\",\n  \"type\": \"STOCK_ADJUSTED\",\n  \"occurredAt\": \"2026-01-01T10:00:00Z\",\n  \"accountId\": \"{{accountId}}\",\n  \"sku\": \"{{sku}}\",\n  \"available\": 10,\n  \"reason\": \"carga_inicial\"\n}"
